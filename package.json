{
  "name": "parse-torrent-path",
  "version": "1.0.0",
  "description": "Modular, handler-based media metadata parser for filenames and paths.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "format": "prettier --write src test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run prepublishOnly && changeset publish"
  },
  "author": "Charles Aldarondo <charles.aldarondo@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.13.5",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.7"
  },
  "dependencies": {
    "parse-torrent-title": "^2.1.0"
  }
}
